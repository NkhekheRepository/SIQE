# SIQE V3 Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env with real API keys.

ENVIRONMENT=development
DEBUG=true
TIMEZONE=UTC

# Trading Settings
INITIAL_EQUITY=10000
MAX_POSITION_SIZE=0.1
MAX_DAILY_LOSS=0.05
MAX_DRAWDOWN=0.20
MIN_EV_THRESHOLD=0.01

# Risk Management
MAX_CONSECUTIVE_LOSSES=5
MAX_TRADES_PER_HOUR=100
PNL_DEVIATION_THRESHOLD=3.0
MIN_TRADES_FOR_ANOMALY_DETECTION=20
VOLATILITY_SCALING=true

# Learning Engine
MIN_SAMPLE_SIZE=50
MAX_PARAM_CHANGE=0.1
ROLLBACK_ENABLED=true

# Regime Engine
REGIME_LOOKBACK_PERIOD=100

# Database
DB_PATH=./data/siqe.db

# Execution
USE_MOCK_EXECUTION=true
SLIPPAGE_MODEL=linear
LATENCY_TOLERANCE_MS=100

# VN.PY Gateway (spot)
VNPY_GATEWAY=BINANCE
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_SERVER=SIMULATOR
PROXY_HOST=
PROXY_PORT=0

# USDT-M Futures Configuration
# Get TESTNET keys from: https://testnet.binancefuture.com
FUTURES_API_KEY=
FUTURES_API_SECRET=
FUTURES_LEVERAGE=50
FUTURES_SYMBOL=btcusdt
FUTURES_RISK_PCT=0.02
FUTURES_MARGIN_ALERT_PCT=0.70
FUTURES_MARGIN_STOP_PCT=0.90
FUTURES_ATR_STOP=1.0
FUTURES_ATR_TRAILING=0.75

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/siqe.log

# API
API_HOST=0.0.0.0
API_PORT=8000

# Strategy Restrictions (comma-separated)
RESTRICTED_SYMBOLS=

# Feature Flags
ENABLE_LEARNING=true
ENABLE_REGIME_DETECTION=true
ENABLE_META_OVERRIDE=true

# Concurrency & Pipeline
MAX_QUEUE_SIZE=1000
MAX_CONCURRENT_EVENTS=4
STAGE_TIMEOUT=5.0
MAX_RETRIES=3
RETRY_BASE_DELAY=0.1
